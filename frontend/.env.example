# Frontend environment (optional). Copy to .env.local if needed.

# Dev (npm run dev from /frontend): leave VITE_API_BASE unset so requests use /api and Vite proxies
# to the backend (see vite.config.ts). This avoids "Not Found" when the UI pointed at the wrong URL.

# VITE_API_BASE=http://localhost:8000/api

# If the backend is not on 127.0.0.1:8000, set the proxy target (dev + vite preview only):
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:9000

# Production build (vite build): set the public API URL your users will call:
# VITE_API_BASE=https://your-server.example/api
