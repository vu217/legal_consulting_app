# Copy to .env and adjust. Backend reads this from the repo root.

QDRANT_URL=http://localhost:6333
COLLECTION=legal_cases
EMBED_MODEL=nomic-embed-text
VECTOR_SIZE=768
LLM_MODEL=deepseek-r1:8b
FAST_LLM_MODEL=llama3.1:8b

# HTTP path prefix for all API routes (default /api). Leave unset or use /api so the frontend matches.
# An empty value in .env is treated as /api to avoid accidental 404s.
# API_PREFIX=/api
